<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <servlet>
        <servlet-name>AddServlet</servlet-name>
        <servlet-class>com.coachhe.servlets.AddServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddServlet</servlet-name>
        <url-pattern>/add</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LifeServlet</servlet-name>
        <servlet-class>com.coachhe.servlets.LifeServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>LifeServlet</servlet-name>
        <url-pattern>/life</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SessionServlet</servlet-name>
        <servlet-class>com.coachhe.servlets.SessionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SessionServlet</servlet-name>
        <url-pattern>/session</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SetAttrubuteServlet</servlet-name>
        <servlet-class>com.coachhe.servlets.Attrubute.SetAttrubuteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SetAttrubuteServlet</servlet-name>
        <url-pattern>/setAttribute</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>GetAttrubuteServlet</servlet-name>
        <servlet-class>com.coachhe.servlets.Attrubute.GetAttrubuteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GetAttrubuteServlet</servlet-name>
        <url-pattern>/getAttribute</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ServerInnerTransfer</servlet-name>
        <servlet-class>com.coachhe.servlets.Transter.ServerInnerTransfer</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ServerInnerTransfer</servlet-name>
        <url-pattern>/serverInnerTransfer</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ClientRedirectServlet</servlet-name>
        <servlet-class>com.coachhe.servlets.Transter.ClientRedirectServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ClientRedirectServlet</servlet-name>
        <url-pattern>/clientRedirectTransfer</url-pattern>
    </servlet-mapping>


    <servlet>
        <servlet-name>FinalServlet</servlet-name>
        <servlet-class>com.coachhe.servlets.Transter.FinalServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FinalServlet</servlet-name>
        <url-pattern>/final</url-pattern>
    </servlet-mapping>



</web-app>